<div class="flex flex-col items-center">
  <h1>Meals#index</h1>

  <% @meals.each do |meal| %>
    <h2 class="meal-title font-bold underline"><%= meal.name %></h2>
    <ul class="meal-details w-80 hidden">
      <% for component in meal.recipe do %>
        <li class="flex justify-between">
            <span>
              <%= component[:amount] %>
              <%= component[:unit] %>
              <%= component[:ingredient] %>
            </span>
            <span>
              <%= number_to_currency component[:cost] %>
            </span>
        </li>
      <% end %>
    </ul>
  <% end %>
</div>

<%= javascript_include_tag 'meals.js' %>
